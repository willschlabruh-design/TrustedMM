generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  password    String
  username    String   @unique
  name        String?
  avatarUrl   String?
  role        String   @default("USER")
  verified    Boolean  @default(false)
  twoFA       Boolean  @default(false)
  twoFASecret String?
  rating      Float    @default(0)
  tradesAsBuyer Trade[] @relation("buyer")
  tradesAsSeller Trade[] @relation("seller")
  tradesAsMiddleman Trade[] @relation("middleman")
  roomMemberships RoomMember[]
  uploadedFiles File[]
  disputesOpened Dispute[]
  verificationTokens VerificationToken[]
  messages     Message[]
  reviews      Review[]
  notifications Notification[]
  sessions     Session[]
  staffApp     StaffApplication?
  createdAt   DateTime @default(now())
}

model Trade {
  id          String   @id @default(cuid())
  title       String
  description String
  platform    String?
  value       Float    @default(0)
  status      String @default("WAITING_FOR_MIDDLEMEN")
  buyer       User?    @relation("buyer", fields: [buyerId], references: [id])
  buyerId     String?
  seller      User?    @relation("seller", fields: [sellerId], references: [id])
  sellerId    String?
  middleman   User?    @relation("middleman", fields: [middlemanId], references: [id])
  middlemanId String?
  messages    Message[]
  files       File[]
  reviews     Review[]
  disputes    Dispute[]
  rooms       Room[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
}

model Message {
  id        String   @id @default(cuid())
  trade     Trade?    @relation(fields: [tradeId], references: [id])
  tradeId   String?
  room      Room?     @relation(fields: [roomId], references: [id])
  roomId    String?
  sender    User      @relation(fields: [senderId], references: [id])
  senderId  String
  body      String
  attachments File[]  @relation("messageFiles")
  createdAt DateTime @default(now())
}

model Room {
  id        String @id @default(cuid())
  trade     Trade? @relation(fields: [tradeId], references: [id])
  tradeId   String?
  messages  Message[]
  members   RoomMember[]
  createdAt DateTime @default(now())
}


model RoomMember {
  id        String @id @default(cuid())
  room      Room   @relation(fields: [roomId], references: [id])
  roomId    String
  user      User   @relation(fields: [userId], references: [id])
  userId    String
  joinedAt  DateTime @default(now())
  @@unique([roomId, userId])
}

model Review {
  id        String @id @default(cuid())
  author    User   @relation(fields: [authorId], references: [id])
  authorId  String
  trade     Trade? @relation(fields: [tradeId], references: [id])
  tradeId   String?
  rating    Int
  text      String?
  createdAt DateTime @default(now())
}

model Notification {
  id        String @id @default(cuid())
  user      User   @relation(fields: [userId], references: [id])
  userId    String
  type      String
  payload   String?
  read      Boolean @default(false)
  createdAt DateTime @default(now())
}

model Session {
  id        String @id @default(cuid())
  user      User   @relation(fields: [userId], references: [id])
  userId    String
  token     String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([token])
}

model File {
  id        String @id @default(cuid())
  url       String
  filename  String
  size      Int
  mime      String
  uploadedBy User? @relation(fields: [uploadedById], references: [id])
  uploadedById String?
  trade     Trade? @relation(fields: [tradeId], references: [id])
  tradeId   String?
  message   Message? @relation("messageFiles", fields: [messageId], references: [id])
  messageId String?
  createdAt DateTime @default(now())
}

model Dispute {
  id        String @id @default(cuid())
  trade     Trade  @relation(fields: [tradeId], references: [id])
  tradeId   String
  openedBy  User   @relation(fields: [openedById], references: [id])
  openedById String
  status    String @default("OPEN")
  reason    String
  resolution String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model StaffApplication {
  id        String @id @default(cuid())
  user      User   @relation(fields: [userId], references: [id])
  userId    String @unique
  bio       String
  status    String @default("PENDING")
  submittedAt DateTime @default(now())
}

model Log {
  id        String @id @default(cuid())
  level     String
  message   String
  meta      String?
  createdAt DateTime @default(now())
}

model VerificationToken {
  id        String @id @default(cuid())
  token     String @unique
  type      String // e.g., "email_verification" | "password_reset" | "2fa"
  user      User   @relation(fields: [userId], references: [id])
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  @@index([token])
}
 
